@model IEnumerable<UrunYonetimSistemi.Models.Product>

    <h2 class="mb-3">Ürün Listesi</h2>

    <a href="/Product/Create" class="btn btn-success mb-3">
        + Yeni Ürün Ekle
    </a>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Ad</th>
                <th>Açıklama</th>
                <th>Fiyat</th>
                <th>Stok</th>
                <th width="180">İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price ₺</td>
                <td>@item.Stock</td>
                <td>
                    <a href="/Product/Edit/@item.Id" class="btn btn-secondary btn-sm">
                        Düzenle
                    </a>

                    <a href="/Product/Delete/@item.Id" class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
